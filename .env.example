OPENAI_API_KEY=
# Optional global model override. If unset, PharmaOS uses route-specific defaults.
PHARMA_OS_MODEL=
# Optional route-specific model overrides.

# Cheap/simple parsing and reporting
PHARMA_OS_MODEL_REQUEST_UNDERSTANDING=gpt-5.4-nano
PHARMA_OS_MODEL_HUMAN_SUMMARY=gpt-5.4-nano

# Orchestration/planning still needs decent reasoning
PHARMA_OS_MODEL_CONTROL_TOWER=gpt-5.4-mini

# Agent 3: clinical outcome prediction
PHARMA_OS_MODEL_AGENT3_MANAGER=gpt-5.4-mini
PHARMA_OS_MODEL_AGENT3_SUBAGENT=gpt-5-mini

# Agent 4: due diligence
PHARMA_OS_MODEL_AGENT4_MANAGER=gpt-5.4-mini
PHARMA_OS_MODEL_AGENT4_SUBAGENT=gpt-5-mini

# Agent 5: protocol design
PHARMA_OS_MODEL_AGENT5_MANAGER=gpt-5.4
PHARMA_OS_MODEL_AGENT5_SUBAGENT=gpt-5.4-mini
# Optional. Leave unset or set true to use live agents when OPENAI_API_KEY is present.
# Set false to force deterministic offline fallbacks.
PHARMA_OS_ENABLE_LIVE_AGENTS=
PHARMA_OS_AGENT_MAX_TURNS=8
PHARMA_OS_AGENTS_DISABLED=false
PHARMA_OS_LLM_MAX_RETRIES=4
PHARMA_OS_LLM_RETRY_INITIAL_DELAY_SECONDS=1.0
PHARMA_OS_LLM_RETRY_MAX_DELAY_SECONDS=30.0
NCBI_API_KEY=
NCBI_EMAIL=
CENSUS_API_KEY=
LENS_API_TOKEN=
PHARMA_OS_POS_WORKBOOK_PATH=data/Source_Based_PoS_Workbook.xlsx
PHARMA_OS_WAC_DATA_PATH=data/california_wac_data.xlsx
# Optional live-test throttles. Lower these to reduce external search volume.
PHARMA_OS_PUBMED_MAX_RESULTS=5
PHARMA_OS_CTGV_MAX_RESULTS=10
PHARMA_OS_LENS_MAX_RESULTS=5
