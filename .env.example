OPENAI_API_KEY=
PHARMA_OS_MODEL=gpt-5.5
# Optional. Leave unset or set true to use live agents when OPENAI_API_KEY is present.
# Set false to force deterministic offline fallbacks.
PHARMA_OS_ENABLE_LIVE_AGENTS=
PHARMA_OS_AGENT_MAX_TURNS=8
PHARMA_OS_AGENTS_DISABLED=false
NCBI_API_KEY=
NCBI_EMAIL=
CENSUS_API_KEY=
LENS_API_TOKEN=
PHARMA_OS_POS_WORKBOOK_PATH=data/Source_Based_PoS_Workbook.xlsx
PHARMA_OS_WAC_DATA_PATH=data/california_wac_data.xlsx
# Optional live-test throttles. Lower these to reduce external search volume.
PHARMA_OS_PUBMED_MAX_RESULTS=5
PHARMA_OS_CTGV_MAX_RESULTS=10
PHARMA_OS_LENS_MAX_RESULTS=5
